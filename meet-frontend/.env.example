# =============================================================================
# Meet Conference — Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env files to version control!
#
# Note: Vite only exposes env vars prefixed with VITE_ to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# Full URL to the backend API server
# Local:  http://localhost:4000/api
# Remote: https://meet.yourdomain.com/api
VITE_API_URL=http://localhost:4000/api

# -----------------------------------------------------------------------------
# LiveKit WebSocket URL
# -----------------------------------------------------------------------------
# WebSocket URL for connecting to the LiveKit media server
# Local:  ws://localhost:7880
# Remote: wss://livekit.yourdomain.com
VITE_LIVEKIT_URL=ws://localhost:7880
