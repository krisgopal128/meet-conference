# =============================================================================
# Meet Conference — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env files to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Node environment: development | production
NODE_ENV=development

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Port the backend API server listens on
PORT=4000

# Frontend URL (used for CORS and generating external links)
# In production, set to your domain: https://meet.yourdomain.com
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# LiveKit — WebRTC Media Server
# -----------------------------------------------------------------------------
# LiveKit server WebSocket URL
# Local:  ws://localhost:7880
# Remote: wss://livekit.yourdomain.com
LIVEKIT_URL=ws://localhost:7880

# API key & secret from your LiveKit server config (livekit.yaml)
# Generate with: livekit-server generate-keys
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
# Full connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meet_db

# --- SSL Options (production only) ---
# Path to CA certificate for database SSL (e.g., /etc/ssl/certs/ca-certificates.crt)
# Uncomment if your database requires SSL with a custom CA
# DATABASE_CA_PATH=/path/to/ca-cert.pem

# Set to 'true' to enable SSL with self-signed certs (development only)
# DATABASE_SSL=true

# Set to 'false' to skip certificate verification (not recommended for production)
# DATABASE_REJECT_UNAUTHORIZED=false

# -----------------------------------------------------------------------------
# Redis — Caching & Sessions
# -----------------------------------------------------------------------------
# Redis connection URL
# Local:  redis://127.0.0.1:6379
# Remote: redis://:password@your-redis-host:6379
REDIS_URL=redis://127.0.0.1:6379

# -----------------------------------------------------------------------------
# Authentication — JWT
# -----------------------------------------------------------------------------
# JWT secret for signing auth tokens
# IMPORTANT: Use a strong random string (32+ characters) in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_secure_random_string_min_32_chars

# Token expiration time (e.g., 1h, 7d, 30d)
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS — Cross-Origin Resource Sharing
# -----------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins
# Add all domains that will access the API
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# S3 Storage — Optional (for recordings)
# -----------------------------------------------------------------------------
# Uncomment and configure if you want recording support
# S3_BUCKET=your-s3-bucket-name
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=your_s3_access_key
# S3_SECRET_KEY=your_s3_secret_key
