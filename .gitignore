# Meet Conference - Root Gitignore

# ============================================
# SECRETS & ENVIRONMENT FILES
# ============================================
.env
.env.local
.env.*.local
*.env

# ============================================
# DATABASE FILES
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# LIVEKIT CONFIG (contains API keys)
# ============================================
livekit/livekit.yaml

# ============================================
# TOOL ARTIFACTS
# ============================================
.code-review-graph/
**/.code-review-graph/
**/.desloppify/
.code-review-graphignore
**/.code-review-graphignore

# ============================================
# BUILD & DEPENDENCIES
# ============================================
node_modules/
dist/
build/
coverage/

# ============================================
# LOGS
# ============================================
logs/
*.log

# ============================================
# IDE & OS
# ============================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================
# TEMPORARY FILES
# ============================================
*.tmp
*.temp
tmp/
temp/
*.pid

# ============================================
# BACKUPS
# ============================================
*.tar.gz
.backup/

# ============================================
# SEED DATA WITH CREDENTIALS
# ============================================
meet-backend/scripts/seed-admin.sql
meet-backend/scripts/seed-mock-data.sql

# ============================================
# SCORECARD IMAGES (tool output)
# ============================================
scorecard.png
**/scorecard.png
