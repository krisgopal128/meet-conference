# Meet Conference - Root Gitignore

# ============================================
# SECRETS & ENVIRONMENT FILES
# ============================================
.env
.env.local
.env.*.local
*.env

# ============================================
# DATABASE FILES
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# LIVEKIT CONFIG (contains API keys)
# ============================================
livekit/livekit.yaml

# ============================================
# TOOL ARTIFACTS
# ============================================
.code-review-graph/
**/.code-review-graph/
**/.desloppify/
.code-review-graphignore
**/.code-review-graphignore

# ============================================
# BUILD & DEPENDENCIES
# ============================================
node_modules/
dist/
build/
coverage/

# ============================================
# LOGS
# ============================================
logs/
*.log

# ============================================
# IDE & OS
# ============================================
.idea/
.vscode/
opencode.json
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================
# TEMPORARY FILES
# ============================================
*.tmp
*.temp
tmp/
temp/
*.pid

# ============================================
# BACKUPS
# ============================================
*.tar.gz
.backup/

# ============================================
# SEED DATA WITH CREDENTIALS
# ============================================
meet-backend/scripts/seed-admin.sql
meet-backend/scripts/seed-admin.ts
meet-backend/scripts/seed-mock-data.sql

# ============================================
# TEST SCRIPTS WITH API KEYS
# ============================================
meet-backend/test-api.sh
meet-backend/test-external.sh

# ============================================
# SCORECARD IMAGES (tool output)
# ============================================
scorecard.png
**/scorecard.png

# ============================================
# DEPLOYMENT CONFIG (server-specific)
# ============================================
Caddyfile.new

# ============================================
# TOOL / WORKSPACE ARTIFACTS
# ============================================
.understand-anything/
test-screenshots/
build_tree.py
bot-simulator/
Camera_BG_Blur/

testsprite_tests/tmp/config.json

# Audit/profiling scripts (not part of the app)
api-profile*.py
page-audit*.py
audit-inject.js
page-audit-results.json
fix-lobby.js
